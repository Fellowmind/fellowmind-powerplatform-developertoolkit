<?xml version="1.0" encoding="utf-8" ?>
<manifest>
  <control namespace="Fellowmind" constructor="EnhancedTextField" version="1.0.0"
           display-name-key="FM Enhanced Text Field" description-key="Enhanced text field with character counter and field-type actions"
           control-type="virtual"
           api-version="1.3.4">

    <external-service-usage enabled="false" />

    <type-group name="TextFieldTypes">
      <type>SingleLine.Text</type>
      <type>SingleLine.TextArea</type>
      <type>SingleLine.Phone</type>
      <type>SingleLine.Email</type>
      <type>SingleLine.URL</type>
      <type>Multiple</type>
    </type-group>

    <property name="value" display-name-key="Value" description-key="The bound text field"
              of-type-group="TextFieldTypes" usage="bound" required="true" />

    <property name="MaxLengthOverride" display-name-key="Max Length Override"
              description-key="Override max length (-1 = use metadata)"
              of-type="Whole.None" usage="input" required="false" default-value="-1" />

    <property name="ShowCounter" display-name-key="Show Counter"
              description-key="Show the character counter"
              of-type="TwoOptions" usage="input" required="false" default-value="true" />

    <property name="ShowIcon" display-name-key="Show Icon"
              description-key="Show field type action icon"
              of-type="TwoOptions" usage="input" required="false" default-value="true" />

    <property name="WarningThresholdPercent" display-name-key="Warning Threshold %"
              description-key="Percentage at which counter shows warning"
              of-type="Whole.None" usage="input" required="false" default-value="80" />

    <property name="ErrorThresholdPercent" display-name-key="Error Threshold %"
              description-key="Percentage at which counter shows error"
              of-type="Whole.None" usage="input" required="false" default-value="95" />

    <resources>
      <code path="index.ts" order="1" />
      <platform-library name="React" version="16.8.6" />
      <platform-library name="Fluent" version="9.46.2" />
    </resources>

  </control>
</manifest>
